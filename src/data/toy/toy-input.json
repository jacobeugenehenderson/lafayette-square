{
  "meta": {
    "source": "toy",
    "description": "Cleanroom test fixture for cartograph plug + ribbon work. TEN variants laid out on a grid: rows 1-2 cover ANGLE regimes (90° X, 60° X, 45° X, T-90°, Y-120°, near-collinear 175°/5° X, sharp 30° X, 5-way 72° spokes); row 3 covers RIBBON-SHAPE regimes (chain bends within corner-pad reach, asymmetric pavement widths). All chains in rows 1-2 share an asymmetric ped-zone measure (left=treelawn+sidewalk, right=sidewalk-only); row 3 mixes those with asymmetric pavement widths (wide left lane vs narrow right lane). Re-run cartograph/derive-toy.js after editing.",
    "grid": {
      "v1_90X":         { "center": [-120,   40] },
      "v2_60X":         { "center": [ -40,   40] },
      "v3_45X":         { "center": [  40,   40] },
      "v4_T90":         { "center": [ 120,   40] },
      "v5_Y120":        { "center": [-120,  -40] },
      "v6_175X":        { "center": [ -40,  -40] },
      "v7_30X":         { "center": [  40,  -40] },
      "v8_5way":        { "center": [ 120,  -40] },
      "v9_bent":        { "center": [-120, -120] },
      "v10_asymmPave":  { "center": [ -40, -120] }
    }
  },
  "_measure_template": {
