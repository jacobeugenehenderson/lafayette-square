    "left":  { "pavementHW": 5, "treelawn": 1.5, "sidewalk": 1.5, "terminal": "sidewalk" },
    "right": { "pavementHW": 5, "treelawn": 0,   "sidewalk": 1.5, "terminal": "sidewalk" }
  },
