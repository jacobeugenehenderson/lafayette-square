{
  "meta": {
    "source": "toy",
    "description": "Cleanroom test fixture for cartograph plug + ribbon work. EIGHT angle-regime variants laid out on a 4×2 grid (80m spacing): 90° X (baseline), 60° X, 45° X, T-junction (90°), Y-junction (120°), near-collinear 175°/5° X (degenerate, expects all-flat corners), sharp 30° X (acute = max angleMult), 5-way (72° spokes). All chains share an asymmetric measure (left=treelawn+sidewalk, right=sidewalk-only) so the angle is the only varying axis. Re-run cartograph/derive-toy.js after editing.",
    "grid": {
      "v1_90X":     { "center": [-120,  40] },
      "v2_60X":     { "center": [ -40,  40] },
      "v3_45X":     { "center": [  40,  40] },
      "v4_T90":     { "center": [ 120,  40] },
      "v5_Y120":    { "center": [-120, -40] },
      "v6_175X":    { "center": [ -40, -40] },
      "v7_30X":     { "center": [  40, -40] },
      "v8_5way":    { "center": [ 120, -40] }
    }
  },
  "_measure_template": {
    "comment": "Inlined per-chain. Asymmetric ped-zones — left has treelawn+sidewalk (full ~8.15m outer); right has sidewalk-only (narrow ~6.65m outer). Mirrors the original toy ped-zone variation.",
    "left":  { "pavementHW": 5, "treelawn": 1.5, "sidewalk": 1.5, "terminal": "sidewalk" },
    "right": { "pavementHW": 5, "treelawn": 0,   "sidewalk": 1.5, "terminal": "sidewalk" }
  },
  "streets": [
    { "id": "v1-x", "name": "v1-x", "highway": "residential",
      "points": [[-150, 40], [-120, 40], [-90, 40]],
      "measure": { "left":{"pavementHW":5,"treelawn":1.5,"sidewalk":1.5,"terminal":"sidewalk"}, "right":{"pavementHW":5,"treelawn":0,"sidewalk":1.5,"terminal":"sidewalk"} },
      "capEnds": { "start": "blunt", "end": "blunt" } },
    { "id": "v1-y", "name": "v1-y", "highway": "residential",
      "points": [[-120, 10], [-120, 40], [-120, 70]],
