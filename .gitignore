# Dependencies
node_modules/

# Build output
dist/

# Environment files (contain API keys)
.env
.env.local
.env.*.local
scripts/.env

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
._*
Thumbs.db

# Logs
*.log
npm-debug.log*

# Temp files
*.zip
*.bak

# Supabase CLI cache (auto-regenerating)
cary/supabase/.temp/

# Python
__pycache__/
*.pyc
.venv/

# Large reference assets (not needed for build)
assets/botanical-reference-hires/
models/
public/models/
# Allow the victorian lamp model (needed at runtime)
!public/models/lamp-posts/
!public/models/lamp-posts/victorian-lamp.glb
public/photos/lafayette-square/

# Raw data cache (regenerable via scripts/)
scripts/raw/*
!scripts/raw/stl_parcels.json
!scripts/raw/osm_street_lamps.json

# Archived/defunct scripts
_archive/

# Cartograph generated output
cartograph/data/*
!cartograph/data/raw/
cartograph/data/raw/*
!cartograph/data/raw/osm.json
!cartograph/data/raw/survey.json
!cartograph/data/raw/elevation.json
!cartograph/data/clean/
cartograph/data/clean/*
!cartograph/data/clean/map.json
cartograph/node_modules/

# Claude Code local settings
.claude/

# ribbons.json snapshot backups created by the pipeline scripts.
# Useful locally for rollback; never wanted in source control.
src/data/ribbons.json.backup-*

# FOR-species20K LiDAR dataset (~51 GB, used as input to the Arborist
# tree-baking pipeline). Lives locally; never committed.
# Source: https://zenodo.org/records/13255198
botanica/
