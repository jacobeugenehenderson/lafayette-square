# Dependencies
node_modules/

# Build output
dist/

# Environment files (contain API keys)
.env
.env.local
.env.*.local
scripts/.env

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
._*
Thumbs.db

# Logs
*.log
npm-debug.log*

# Temp files
*.zip
*.bak

# Supabase CLI cache (auto-regenerating)
cary/supabase/.temp/

# Python
__pycache__/
*.pyc
.venv/

# Large reference assets (not needed for build)
assets/botanical-reference-hires/
models/
public/models/
# Allow the victorian lamp model (needed at runtime)
!public/models/lamp-posts/
!public/models/lamp-posts/victorian-lamp.glb
public/photos/lafayette-square/

# Raw data cache (regenerable via scripts/)
scripts/raw/*
!scripts/raw/stl_parcels.json
!scripts/raw/osm_street_lamps.json

# Archived/defunct scripts
_archive/

# Cartograph generated output (per-scene data layout: cartograph/data/<scene>/).
# LS scene: most files are local-only (regenerated by the pipeline); only
# the OSM-fetched inputs and the bundled map.json are committed.
# Toy scene: fully committed — toy is a shipped fixture, not workspace state.
cartograph/data/*
!cartograph/data/lafayette-square/
!cartograph/data/toy/
cartograph/data/lafayette-square/*
!cartograph/data/lafayette-square/neighborhood_boundary.json
!cartograph/data/lafayette-square/raw/
!cartograph/data/lafayette-square/clean/
cartograph/data/lafayette-square/raw/*
!cartograph/data/lafayette-square/raw/osm.json
!cartograph/data/lafayette-square/raw/survey.json
!cartograph/data/lafayette-square/raw/elevation.json
cartograph/data/lafayette-square/clean/*
!cartograph/data/lafayette-square/clean/map.json
cartograph/node_modules/

# Claude Code local settings
.claude/

# ribbons.json snapshot backups created by the pipeline scripts.
# Useful locally for rollback; never wanted in source control.
src/data/ribbons.json.backup-*

# FOR-species20K LiDAR dataset (~51 GB, used as input to the Arborist
# tree-baking pipeline). Lives locally; never committed.
# Source: https://zenodo.org/records/13255198
botanica/

# Arborist operator state + caches. Curated picks live in arborist/state/;
# .laz → .ply preview conversion cache lives in arborist/_cache/. Both
# regenerable; never committed.
arborist/state/
arborist/_cache/
arborist/.venv/

# Arborist raw-GLB library. Authoring-only source pool the Arborist
# reads from; never read by runtime. The published artifact runtime
# consumes is the per-Look bake at public/baked/<look>/, written by
# arborist/bake-look.js. Library is multi-GB and regenerable; never
# commit it. See ARCHITECTURE.md §1 for the publish-loop rule.
public/trees/
